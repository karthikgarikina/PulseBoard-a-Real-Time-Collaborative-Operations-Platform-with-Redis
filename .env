APP_NAME=PulseBoard
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

SESSION_TTL_SECONDS=3600
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
FEED_MAX_ITEMS=100

STREAM_EVENTS_KEY=stream:events
STREAM_EVENTS_GROUP=pulseboard-workers
QUEUE_JOBS_KEY=queue:jobs
SCHEDULED_JOBS_KEY=schedule:jobs

WORKER_CONSUMER_NAME=worker-1
SCHEDULER_POLL_SECONDS=5
LOCK_TTL_SECONDS=60

SUBSCRIBER_CHANNELS=channel:demo:messages,channel:demo:typing
